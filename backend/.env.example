NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=stealthera_rpm
MONGO_MAX_POOL_SIZE=50

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h

AUTH_ENABLED=true
DEVICE_API_KEYS=st-device-key-local

GENETICS_API_BASE_URL=http://127.0.0.1:4000/api/v1
GENETICS_API_TIMEOUT_MS=4000
GENETICS_CACHE_TTL_MS=300000

CORS_ORIGINS=*

HR_HIGH_BPM=120
HR_LOW_BPM=45
SPO2_LOW_PERCENT=92
TEMP_HIGH_C=38
TEMP_LOW_C=35
INACTIVITY_STEPS_MIN=100

DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500
DEFAULT_HISTORY_LIMIT=200
MAX_HISTORY_LIMIT=2000

SEED_ADMIN_EMAIL=admin@stealthera.health
SEED_ADMIN_PASSWORD=StealthEra#2026
